{
  "name": "@bpair/cli",
  "version": "0.2.0",
  "description": "CLI transport for BPMax-Air.",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "bpair": "dist/index.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup --config tsup.config.ts && node ./scripts/fix-node-builtins.mjs",
    "pack:dry-run": "pnpm pack --pack-destination ../../.artifacts"
  },
  "dependencies": {
    "commander": "^14.0.1",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@bpair/core": "workspace:*",
    "@bpair/storage-sqlite": "workspace:*"
  }
}
