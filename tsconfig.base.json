{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@bpair/shared": ["packages/shared/src/index.ts"],
      "@bpair/core": ["packages/core/src/index.ts"],
      "@bpair/storage-sqlite": ["packages/storage-sqlite/src/index.ts"],
      "@bpair/sdk": ["packages/sdk/src/index.ts"]
    }
  }
}
