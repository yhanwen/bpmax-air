{
  "name": "bpmax-air",
  "version": "0.1.0",
  "private": true,
  "description": "AI-first headless BPM engine with flow/form JSON DSL, CLI, HTTP API, and general-purpose agent skill integration.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yanghanwen/bpmax-air.git"
  },
  "homepage": "https://github.com/yanghanwen/bpmax-air",
  "bugs": {
    "url": "https://github.com/yanghanwen/bpmax-air/issues"
  },
  "keywords": [
    "bpm",
    "workflow",
    "forms",
    "cli",
    "ai",
    "agent",
    "typescript",
    "headless"
  ],
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "check": "pnpm build && pnpm test",
    "dev:cli": "tsx packages/cli/src/index.ts",
    "dev:server": "tsx packages/server/src/index.ts",
    "gen:blueprint": "tsx tools/generate-blueprint.ts",
    "pack:cli": "pnpm --filter @bpair/cli pack:dry-run"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^24.0.15",
    "tsup": "^8.3.5",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4",
    "yaml": "^2.8.1"
  }
}
